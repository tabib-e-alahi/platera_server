model ProviderProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName     String
  businessCategory BusinessCategory
  phone            String
  businessEmail    String           @unique
  bio              String?
  imageURL         String?

  binNumber   String?
  binVerified Boolean @default(false)

  nidImageFront_and_BackURL String?

  businessMainGateURL String?
  businessKitchenURL  String?

  city        String
  street      String
  houseNumber String
  apartment   String?
  postalCode  String

  approvalStatus  ApprovalStatus @default(DRAFT)
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // finance summary fields
  totalOrdersCompleted Int       @default(0)
  totalGrossRevenue    Decimal   @default(0) @db.Decimal(12, 2)
  totalPlatformFee     Decimal   @default(0) @db.Decimal(12, 2)
  totalProviderEarning Decimal   @default(0) @db.Decimal(12, 2)
  currentPayableAmount Decimal   @default(0) @db.Decimal(12, 2)
  lastPaymentAt        DateTime?

  meals    Meal[]
  reviews  Review[]
  carts    Cart[]
  orders   Order[]
  payments Payment[]

  @@index([userId])
  @@index([city])
  @@index([approvalStatus])
  @@map("provider_profile")
}
