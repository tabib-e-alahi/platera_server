model Order {
  id String @id @default(uuid())

  orderNumber   String        @unique
  customerId    String
  providerId    String
  paymentMethod PaymentMethod

  status                OrderStatus @default(PENDING_PAYMENT)
  customerName          String?
  customerPhone         String?
  deliveryCity          String
  deliveryStreetAddress String?
  deliveryHouseNumber   String?
  deliveryApartment     String?
  deliveryPostalCode    String?
  deliveryNote          String?
  subtotal              Decimal     @db.Decimal(12, 2)
  deliveryFee           Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount        Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal     @db.Decimal(12, 2)
  placedAt              DateTime?
  acceptedAt            DateTime?
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  customer User            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Restrict)

  items    OrderItem[]
  payments Payment[]

  @@index([customerId])
  @@index([providerId])
  @@index([status])
  @@map("orders")
}
