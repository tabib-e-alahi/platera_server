model OrderItem {
  id             String   @id @default(uuid())

  orderId        String
  mealId         String

  // Snapshot fields (DO NOT depend on Meal later)
  mealName       String
  mealSlug       String?
  mealImageUrl   String?

  quantity       Int

  unitPrice      Decimal  @db.Decimal(12, 2)
  totalPrice     Decimal  @db.Decimal(12, 2)

  createdAt      DateTime @default(now())

  // Relations
  order          Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([mealId])
  @@map("order_items")
}