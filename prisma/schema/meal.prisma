model Meal {
  id String @id @default(uuid())

  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // core info
  name             String
  subcategory      String?
  shortDescription String
  fullDescription  String?
  portionSize      String?

  // media
  mainImageURL     String
  galleryImageURLs String[]

  // pricing
  basePrice         Int
  discountPrice     Int?
  discountStartDate DateTime?
  discountEndDate   DateTime?

  // dietary and allergens
  dietaryPreferences DietaryPreference[]
  allergens          String[]

  // nutrition (optional)
  calories      Int?
  protein       Float?
  fat           Float?
  carbohydrates Float?

  // availability
  isAvailable            Boolean @default(true)
  isActive               Boolean @default(true)
  preparationTimeMinutes Int     @default(15)

  // flags
  isBestseller Boolean @default(false)
  isFeatured   Boolean @default(false)

  // tags
  tags String[]

  // delivery
  deliveryFee Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  sizes         MealSize[]
  spiceLevels   MealSpiceLevel[]
  addOns        MealAddOn[]
  removeOptions MealRemoveOption[]
  ingredients   MealIngredient[]
  reviews       Review[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([providerId])
  @@index([categoryId])
  @@index([isAvailable, isActive])
  @@map("meal")
}

enum DietaryPreference {
  VEGAN
  VEGETARIAN
  HALAL
  GLUTEN_FREE
  DAIRY_FREE
  NUT_FREE
  ORGANIC
  LOW_CARB
  KETO
  PALEO
  LOW_FAT
  HIGH_PROTEIN
  LOW_SUGAR
  SUGAR_FREE
  FODMAP_FREE
}
