model MealSize {
  id         String  @id @default(uuid())
  mealId     String
  name       String
  extraPrice Int     @default(0)
  isDefault  Boolean @default(false)
  meal       Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
  @@map("meal_size")
}

model MealSpiceLevel {
  id        String  @id @default(uuid())
  mealId    String
  level     String
  isDefault Boolean @default(false)
  meal      Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
  @@map("meal_spice_level")
}

model MealAddOn {
  id     String @id @default(uuid())
  mealId String
  name   String
  price  Int
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
  @@map("meal_add_on")
}

model MealRemoveOption {
  id     String @id @default(uuid())
  mealId String
  name   String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
  @@map("meal_remove_option")
}

model MealIngredient {
  id     String @id @default(uuid())
  mealId String
  name   String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
  @@map("meal_ingredient")
}
