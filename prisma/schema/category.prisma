// prisma/schema/category.prisma

model Category {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  imageURL     String   
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  meals Meal[]

  @@index([slug])
  @@map("category")
}